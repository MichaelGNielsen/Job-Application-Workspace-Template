# === System Konfiguration ===
# (Systemet udleder automatisk navn/branding fra data/brutto_cv.md)

# === AI Provider URLs ===
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2:9b
OPENCODE_URL=http://host.docker.internal:4096
AI_PROVIDER=gemini
AI_CALL_COOLDOWN_MS=1000

# === Gemini AI Konfiguration ===
# Hent din API nøgle her: https://aistudio.google.com/app/apikey
# VIGTIGT: Din API-nøgle skal enten sættes her (i .env) ELLER
# eksporteres som en global variabel i din .bashrc (anbefalet for sikkerhed).
# 
# BEMÆRK (GDPR / Rate Limits): I EU kan rene API-nøgler være stærkt begrænsede og give
# 'RATE_LIMIT_EXCEEDED' fejl. Løsningen er at logge ind via din lokale terminal
# (kør 'gemini login' på host-maskinen). Docker-containeren låner derefter automatisk 
# dine browser-credentials via mappen ~/.gemini, hvilket fjerner begrænsningerne.
GEMINI_API_KEY="din-nøgle-her"
GOOGLE_API_KEY=YOUR_API_KEY_HERE

# Model valg (Tilgængelige Gemini modeller via CLI):
# gemini-3.1-pro-preview
# gemini-3-flash-preview (Tidligere standard)
# gemini-3.1-flash-lite-preview 
# gemini-2.5-pro
# gemini-2.5-flash (Ny anbefalet standard)
# gemini-2.5-flash-lite

GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MAX_BUFFER_MB=100

 
# Verbose output for debugging 
# * VERBOSE=""    : Kun ERROR, WARN og basis INFO.
# * VERBOSE="-v"   : Viser data (afkortet ved 500 tegn).
# * VERBOSE="-vv"  : Viser ALT (Fulde prompts og svar).
VERBOSE=""
DEBUG=true

ENABLE_STARTUP_SELF_TEST=true